<html>
    <head>
        <title> button </title>
    </head>
    <style>
        body
        {
            background-color: black;
            font-size:10px;
            padding:15px;
            margin:15px;
        }
        .all
        {
            text-decoration: none;
            display: inline-flex;
            padding:15px;
            margin:15px;
        }
        .hide
        {
            display:none;
        }
        
        .shreyash
        {
            color:white;
           font-size:8px;
           background-color: black;
           padding: 15px;
           margin:15px;
           box-shadow: 5px 0 20px rgb(71, 211, 89);
           animation-name:border1;
           animation-duration: 1s;
           animation-iteration-count: infinite;
        }
        .bhuro
        {
            background-color: black;
            font-size:8px;
            padding: 15px;
            margin: 15px;
            color:white;
            animation-name: border2;
            animation-duration: 1s;
            animation-iteration-count: infinite;
            box-shadow: 5px 0 20px rgb(212 ,20 ,20 );
        }
        .ankit
        {
            background-color: black;
            font-size:8px;
            padding:15px;
            margin:15px;
            color:white;
            animation-name:border3;
            animation-iteration-count: infinite;
            box-shadow: 5px 0 20px rgb(19, 143, 214);
            animation-duration: 1s;
        }
        .a1,.a2,.a3
        {
            text-decoration: none;
        }
        a:visited
        {
            color:yellowgreen;
        }
       .shreyash:hover
       {
        background-color: rgba(88, 228, 33, 0.8);
        color:black;
        display:block;
        -webkit-box-reflect: below 0px linear-gradient(to bottom , rgb(88, 228, 33, 1) , rgba(88, 228, 33, 0.4));
       }
       
       .ankit:hover{
        
        background-color: rgba(19, 143, 214, 0.8);
        color:black;
        -webkit-box-reflect: below 0px linear-gradient(to bottom , rgba(19, 143, 214, 1) , rgba(19, 143, 214, 0.4));
       }
       .bhuro:hover
       {
        background-color: rgba(243, 27, 27, 0.8);
        color:black;
        -webkit-box-reflect: below 0px linear-gradient(to bottom , rgba(243, 27, 27, 1) , rgba(243, 27, 27, 0.4) );
       }

      @keyframes border1
       {
        0% { border-left: 2px solid  green; }
        25%{border-top: 2px solid green;}
        50%{border-right:2px solid green; }
        100%{border-bottom: 2px solid green;}
        }
        @keyframes border2
       {
        0% { border-left: 2px solid  rgb(212, 20, 20);}
        25%{border-top: 2px solid rgb(212, 20, 20);}
        50%{border-right:2px solid rgb(212, 20, 20);}
        100%{border-bottom: 2px solid rgb(212, 20, 20);}
        }
        @keyframes border3
       {
        0% { border-left: 2px solid  rgb(19, 143, 214);}
        25%{border-top: 2px solid rgb(19, 143, 214);}
        50%{border-right:2px solid rgb(19, 143, 214);}
        100%{border-bottom: 2px solid rgb(19, 143, 214);}
        }


       
    </style>
    <body>
        
       <ul class="all" type="none">
            <li class="shreyash">shreyash</a></li>
            <li class="bhuro">bhuro</a></li>
            <li class="ankit">ankit</a></li>
       </ul>
       
    </div>



  
    </body>
</html>
